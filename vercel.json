{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install && npx prisma generate",
  "functions": {
    "api/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/dist/client/assets/$1"
    },
    {
      "src": "^/(favicon\\.ico|favicon\\.png|robots\\.txt|manifest.*|.*\\.svg)$",
      "dest": "/dist/client/$1"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.js"
    }
  ]
}