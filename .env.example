# ─── App / Base Config ────────────────────────────────────────
BASE_URL=https://hubmc.in

# ─── Auth / Session ───────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret

# ─── Super Admin ──────────────────────────────────────────────
SUPER_ADMIN_ID=HUB_MC_ADMIN
SUPER_ADMIN_PASSWORD=change-me

# ─── Database (MySQL connection string) ───────────────────────
# LOCAL DEV: Set this to your MySQL connection string
# CLOUDFLARE: NOT used — Hyperdrive binding provides the connection string
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── YouTube ──────────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=UC0Krc1QNCKs6jovdXe5WICA

# ─── Discord ──────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_SERVER_ID=1425411040329465878
DISCORD_INVITE=https://discord.gg/CwNVBCuSbj

# ─── Minecraft RCON ──────────────────────────────────────────
MC_RCON_HOST=
MC_RCON_PORT=25575
MC_RCON_PASSWORD=

# ─── Cloudflare-specific (set via wrangler secret / dashboard) ──
# These are sensitive and must NOT be committed.
# Set them with: wrangler secret put <NAME>
#
# DATABASE_URL          (NOT used on Cloudflare — Hyperdrive binding used instead)
# JWT_SECRET
# SUPER_ADMIN_PASSWORD
# GOOGLE_CLIENT_SECRET
# YOUTUBE_API_KEY
# DISCORD_BOT_TOKEN
# MC_RCON_PASSWORD
#
# Hyperdrive + R2 bindings are configured via:
#   Cloudflare Dashboard > Pages > Settings > Bindings
#   or wrangler.jsonc for local dev (wrangler pages dev)

# ─── Client-side (Vite-exposed, prefix with VITE_) ───────────
VITE_GA_ID=
VITE_CLARITY_ID=
VITE_SENTRY_DSN=
