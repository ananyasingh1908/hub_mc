generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  EMPLOYEE
  CUSTOMER
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  AWAITING_SERVER
}

enum PaymentMethod {
  CARD
  UPI
  NETBANKING
  WALLET
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  name               String?
  image              String?
  microsoftAccountId String?         @unique
  passwordHash       String?
  role               UserRole        @default(CUSTOMER)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  customer           Customer?
  employee           Employee?
  orders             Order[]
  carts              Cart[]
  serverReviews      ServerReview[]
  supportTickets     SupportTicket[] @relation("SupportTicketRequester")
  Notification       Notification[]
  tournamentRegistrations TournamentRegistration[]
}

model Customer {
  id                String          @id @default(cuid())
  userId            String          @unique
  minecraftUsername String          @unique
  minecraftUuid     String          @unique
  avatarUrl         String?
  skinUrl           String?
  lastLoginAt       DateTime?
  country           String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  carts             Cart[]
  orders            Order[]
  serverReviews     ServerReview[]
  supportTickets    SupportTicket[] @relation("CustomerTickets")
  playerRanks PlayerRank[]
}

model Employee {
  id              String          @id @default(cuid())
  userId          String          @unique
  displayName     String
  department      String?
  isActive        Boolean         @default(true)
  disabledAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTickets SupportTicket[] @relation("AssignedEmployee")
  ticketReplies   TicketReply[]
  permissions     RolePermission?
  activityLogs    ActivityLog[]
  playerNotes PlayerNote[]
  playerBans PlayerBan[]
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String      @db.Text
  imageUrl    String
  price       Decimal     @db.Decimal(10, 2)
  active      Boolean     @default(true)
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model Cart {
  id         String     @id @default(cuid())
  userId     String?
  customerId String?
  status     String     @default("ACTIVE")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items      CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
}

model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  description    String
  discountType   String   @default("PERCENTAGE")
  percentageOff  Int?
  amountOff      Decimal? @db.Decimal(10, 2)
  active         Boolean  @default(true)
  maxRedemptions Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
}

model PendingOrder {
  id                String   @id @default(cuid())
  razorpayOrderId   String   @unique
  minecraftUsername String
  minecraftUuid     String
  email             String
  country           String
  paymentMethod     String
  lines             Json
  coupon            Json?
  subtotal          Decimal  @db.Decimal(10, 2)
  discountAmount    Decimal  @db.Decimal(10, 2)
  total             Decimal  @db.Decimal(10, 2)
  customerId        String?
  receipt           String   @unique
  expiresAt         DateTime
  createdAt         DateTime @default(now())
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       String         @unique
  userId            String?
  customerId        String?
  couponId          String?
  minecraftUsername String
  minecraftUuid     String
  email             String
  country           String
  status            OrderStatus    @default(PENDING)
  paymentMethod     PaymentMethod
  subtotal          Decimal        @db.Decimal(10, 2)
  discountAmount    Decimal        @default(0) @db.Decimal(10, 2)
  total             Decimal        @db.Decimal(10, 2)
  razorpayOrderId   String?        @unique
  razorpayPaymentId String?        @unique
  razorpaySignature String?
  receipt           String?        @unique
  paymentVerifiedAt DateTime?
  refundedAt        DateTime?
  refundReason      String?
  deliveryStatus    DeliveryStatus @default(PENDING)
  deliveredAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer          Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  coupon            Coupon?        @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items             OrderItem[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model SupportTicket {
  id           String        @id @default(cuid())
  userId       String?
  customerId   String?
  assignedToId String?
  subject      String
  message      String        @db.Text
  status       TicketStatus  @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  requester    User?         @relation("SupportTicketRequester", fields: [userId], references: [id], onDelete: SetNull)
  customer     Customer?     @relation("CustomerTickets", fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo   Employee?     @relation("AssignedEmployee", fields: [assignedToId], references: [id], onDelete: SetNull)
  replies      TicketReply[]
}

model TicketReply {
  id         String        @id @default(cuid())
  ticketId   String
  employeeId String?
  authorName String
  message    String        @db.Text
  createdAt  DateTime      @default(now())
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  employee   Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model ActivityLog {
  id         String    @id @default(cuid())
  employeeId String?
  action     String
  entity     String
  entityId   String?
  details    String?   @db.Text
  severity   String    @default("INFO")
  ipAddress  String?
  createdAt  DateTime  @default(now())
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model RolePermission {
  id            String   @id @default(cuid())
  employeeId    String   @unique
  products      Boolean  @default(true)
  orders        Boolean  @default(true)
  support       Boolean  @default(true)
  customers     Boolean  @default(false)
  employees     Boolean  @default(false)
  logs          Boolean  @default(false)
  settings      Boolean  @default(false)
  tournaments   Boolean  @default(true)
  notifications Boolean  @default(true)
  playerManage  Boolean  @default(true)
  employeeMonitor Boolean @default(false)
  platformLogs  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  message   String   @db.Text
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model YouTubeContent {
  id           String    @id @default(cuid())
  channelId    String
  videoId      String    @unique
  title        String
  description  String    @db.Text
  thumbnailUrl String?
  publishedAt  DateTime?
  contentType  String    @default("UPLOAD")
  isLive       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model FeaturedStream {
  id            String    @id @default(cuid())
  videoId       String    @unique
  channelId     String
  channelTitle  String
  title         String
  description   String    @db.Text
  thumbnailUrl  String?
  liveViewers   Int       @default(0)
  status        String    @default("PENDING")
  moderatedById String?
  moderatedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model StreamBlacklist {
  id          String    @id @default(cuid())
  channelId   String    @unique
  channelTitle String?
  reason      String?   @db.Text
  createdById String?
  createdAt   DateTime  @default(now())
}

model DiscordEvent {
  id             String    @id @default(cuid())
  eventId        String    @unique
  name           String
  description    String    @db.Text
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  memberCount    Int       @default(0)
  status         String    @default("SCHEDULED")
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ServerReview {
  id                String    @id @default(cuid())
  userId            String?
  customerId        String?
  minecraftUsername String
  rating            Int
  title             String
  message           String    @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([userId])
}

enum TournamentStatus {
  UPCOMING
  LIVE
  COMPLETED
}

enum TournamentType {
  SOLO
  DUO
  SQUAD
}

model Tournament {
  id                  String                @id @default(cuid())
  title               String
  bannerUrl           String?
  type                TournamentType        @default(SOLO)
  gameMode            String
  dateTime            DateTime
  registrationDeadline DateTime
  maxParticipants     Int
  entryFee            Decimal?              @db.Decimal(10, 2)
  prizePool           String?
  discordLink         String?
  rules               String                @db.Text
  serverIp            String?
  status              TournamentStatus      @default(UPCOMING)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  registrations       TournamentRegistration[]
  announcements       TournamentAnnouncement[]
  playerBans          PlayerBan[]
  matches             TournamentMatch[]
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
}

model TournamentMatch {
  id            String         @id @default(cuid())
  tournamentId  String
  round         Int
  matchIndex    Int
  player1Id     String?
  player2Id     String?
  winnerId      String?
  score1        Int?
  score2        Int?
  status        MatchStatus    @default(SCHEDULED)
  scheduledAt   DateTime?
  playedAt      DateTime?
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tournament    Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  player1       TournamentRegistration? @relation("MatchPlayer1", fields: [player1Id], references: [id], onDelete: SetNull)
  player2       TournamentRegistration? @relation("MatchPlayer2", fields: [player2Id], references: [id], onDelete: SetNull)
  winner        TournamentRegistration? @relation("MatchWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@unique([tournamentId, round, matchIndex])
}

model TournamentRegistration {
  id              String       @id @default(cuid())
  tournamentId    String
  userId          String?
  minecraftUsername String
  minecraftUuid   String?
  discordUsername String
  discordId       String?
  teamName        String?
  teamMembers     String?      @db.Text
  email           String
  region          String
  age             Int?
  agreedToRules   Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  tournament      Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  matchesAsPlayer1 TournamentMatch[] @relation("MatchPlayer1")
  matchesAsPlayer2 TournamentMatch[] @relation("MatchPlayer2")
  matchesWon       TournamentMatch[] @relation("MatchWinner")

  @@unique([tournamentId, minecraftUsername])
}

model TournamentAnnouncement {
  id            String     @id @default(cuid())
  tournamentId  String
  title         String
  message       String     @db.Text
  type          String     @default("INFO")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model SiteNotification {
  id        String   @id @default(cuid())
  title     String
  message   String   @db.Text
  type      String   @default("INFO")
  link      String?
  startAt   DateTime @default(now())
  expireAt  DateTime?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerNote {
  id              String    @id @default(cuid())
  employeeId      String?
  customerId      String?
  minecraftUsername String
  note            String    @db.Text
  severity        String    @default("INFO")
  createdAt       DateTime  @default(now())
  employee        Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model PlayerBan {
  id              String    @id @default(cuid())
  employeeId      String?
  customerId      String?
  minecraftUsername String
  reason          String    @db.Text
  tournamentId    String?
  bannedUntil     DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  employee        Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  tournament      Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
}

model PlayerRank {
  id              String    @id @default(cuid())
  customerId      String?
  minecraftUsername String
  rank            String
  assignedBy      String?
  assignedAt      DateTime  @default(now())
  expiresAt       DateTime?
  active          Boolean   @default(true)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, rank])
}
